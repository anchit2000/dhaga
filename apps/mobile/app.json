{
  "expo": {
    "name": "Dhaga",
    "slug": "dhaga",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dhaga",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.dhaga.app"
    },
    "android": {
      "package": "com.dhaga.app",
      "adaptiveIcon": {
        "backgroundColor": "#0d0b09",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0d0b09",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Dhaga uses the camera to scan business cards and badges."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Dhaga uses your coarse location to group scans from the same event into a session. Nothing is captured until you scan."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Dhaga uses the microphone to transcribe voice notes for a new contact. Audio stays on your device.",
          "speechRecognitionPermission": "Dhaga uses on-device speech recognition to turn what you say into text. Nothing is sent to a server."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
