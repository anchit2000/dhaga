# Copy to .env.local in this directory (never commit real values).

# Cloud AI (server-only — never expose to the client bundle).
# Optional: without it, capture falls back to the no-LLM heuristic parser
# and AI features show a "not configured" message.
ANTHROPIC_API_KEY=

# Password for the single-user web app login (required to enter /app).
DHAGA_PASSWORD=

# Secret used to sign the session cookie. Any long random string.
DHAGA_SESSION_SECRET=

# Email (optional — waitlist confirmations + session digests via Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL="dhaga <noreply@yourdomain.com>"
DHAGA_OWNER_EMAIL=   # where YOUR digests get sent

# Hosted Postgres (Neon/Supabase/self-hosted). When set, the app uses it
# instead of the embedded local database — REQUIRED on serverless hosts
# (Vercel). The database must allow CREATE EXTENSION vector (pgvector).
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Telegram bot (optional — capture/query from chat, ideas.md #6).
# Create a bot with @BotFather, then register the webhook:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#     -d "url=https://your-domain/api/telegram" -d "secret_token=<SECRET>"
# Your chat id: message the bot, then check getUpdates once.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Outbound webhooks (optional — Zapier/automation). One URL receives
# {event, at, data} for contact.created and followup.created.
DHAGA_WEBHOOK_URL=

# Optional overrides:
# DHAGA_AI_MONTHLY_CAP=500     # cloud AI actions per month (default 25)
# DHAGA_DATA_DIR=/var/lib/dhaga  # where the embedded DB lives (default .dhaga-data)
# DHAGA_EMBEDDINGS=off         # disable local semantic indexing
