# Copy to .env.local in this directory (never commit real values).

# Canonical public site URL — the base for absolute URLs in metadata, the
# sitemap, robots.txt, JSON-LD, llms.txt, and blog share links. Set this to your
# deployment's public origin; defaults to the production deployment when unset.
NEXT_PUBLIC_SITE_URL=https://dhaga-web.vercel.app

# Cloud AI (server-only — never expose to the client bundle).
# Optional: without it, capture falls back to the no-LLM heuristic parser.
# Anthropic remains the default for backward compatibility. OpenAI-compatible
# servers usually require model names that exist on that server.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EXTRACT_MODEL=gpt-4.1-mini
OPENAI_REASON_MODEL=gpt-4.1
# Contact text policy: auto uses the selected LLM with heuristic fallback;
# heuristic guarantees a zero-cost, offline-only parse.
CONTACT_PARSE_STRATEGY=auto

# Auth (better-auth). BETTER_AUTH_SECRET: any long random string
# (`openssl rand -base64 32`). BETTER_AUTH_URL: this deployment's base URL.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Social sign-in (all optional — each provider's buttons only appear once
# both its vars are set). NEXT_PUBLIC_GOOGLE_CLIENT_ID also enables Google
# One Tap on the login page (client id is public by design; the secret isn't).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Calendar integration (optional — connect Google/Microsoft to suggest open
# meeting times and flag overloaded days; read-only free/busy, never written).
# Reuses the GOOGLE_/MICROSOFT_ client ids above, but the OAuth app must also
# register the calendar redirect URIs and request calendar scopes:
#   Google:    https://<BETTER_AUTH_URL>/api/calendar/callback/google  (scope calendar.freebusy)
#   Microsoft: https://<BETTER_AUTH_URL>/api/calendar/callback/microsoft (scope Calendars.Read)
# CALENDAR_TOKEN_SECRET encrypts stored OAuth tokens at rest (any long random
# string; falls back to BETTER_AUTH_SECRET when unset).
CALENDAR_TOKEN_SECRET=
# DHAGA_CALENDAR_DEMO exposes a synthetic "Demo Calendar" you can connect with
# no real OAuth app (on by default; set to false to hide it in production).
DHAGA_CALENDAR_DEMO=true

# SMS (optional — phone number sign-in/2FA via Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email (optional — access-request confirmations + session digests via Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL="dhaga <noreply@yourdomain.com>"
DHAGA_OWNER_EMAIL=   # where YOUR digests get sent

# Hosted Postgres (Neon/Supabase/self-hosted). When set, the app uses it
# instead of the embedded local database — REQUIRED on serverless hosts
# (Vercel). The database must allow CREATE EXTENSION vector (pgvector).
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Telegram bot (optional — capture/query from chat, ideas.md #6).
# Create a bot with @BotFather, then register the webhook:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#     -d "url=https://your-domain/api/telegram" -d "secret_token=<SECRET>"
# Your chat id: message the bot, then check getUpdates once.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Web search for job-change detection + the news watchlist (optional, BRD
# §6.7). Provider-agnostic gateway (see CLAUDE.md "Search gateway pattern") —
# Firecrawl is the default because it's billed per search, not per model
# call. Star a contact's "Watch for job changes & news" toggle to opt it in;
# a cron hits /api/jobs/detect-signals to run the sweep (CRON_SECRET below).
SEARCH_PROVIDER=firecrawl
FIRECRAWL_API_KEY=

# Cron auth for /api/jobs/daily (once-a-day work: signal detection + the
# reach-out digest — one endpoint so Vercel Hobby's single-cron limit fits).
# Vercel Cron sends this automatically once set (see apps/web/vercel.json);
# OFF Vercel, point any scheduler at the same URL with the same header — e.g.
# scripts/run-daily-jobs.sh, or directly:
#   curl -H "Authorization: Bearer $CRON_SECRET" https://your-domain/api/jobs/daily
# Unset = the route always rejects (fails closed, never runs unauthenticated).
CRON_SECRET=

# Outbound webhooks (optional — Zapier/automation). One URL receives
# {event, at, data} for contact.created and followup.created.
DHAGA_WEBHOOK_URL=

# Blog comments + reactions (optional — powered by giscus / GitHub Discussions).
# All four IDs are required for the comment section to render; without them it's
# simply hidden. Setup: enable Discussions on the repo, install the giscus app
# (github.com/apps/giscus), then copy the repo/category IDs from giscus.app.
# These are NEXT_PUBLIC_ (public by design — the IDs are not secrets).
# NEXT_PUBLIC_GISCUS_THEME is any giscus theme name (default: dark_dimmed).
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
NEXT_PUBLIC_GISCUS_THEME=dark_dimmed

# Non-browser clients (browser extension, future mobile app/scripts) call
# /api/* with an `x-api-key` header — create one per account from
# /app/settings once signed in (replaces the old single shared API token).

# Optional overrides:
# DHAGA_AI_MONTHLY_CAP=500     # cloud AI actions per month (default 25)
# DHAGA_DATA_DIR=/var/lib/dhaga  # where the embedded DB lives (default .dhaga-data)
# DHAGA_EMBEDDINGS=off         # disable local semantic indexing

# Dhaga Cloud only (multi-tenancy, early access, admin panel, billing) — not
# needed for self-hosting. See packages/ee/.env.example and SELF_HOSTING.md.
