{
  "name": "dhaga",
  "private": true,
  "description": "Dhaga — every thread, remembered. Open-source AI-native personal CRM.",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "postcss": "^8.5.16",
    "postcss@8.4.31": "^8.5.16",
    "sharp": "^0.35.0",
    "adm-zip": "^0.6.0",
    "@hono/node-server": "^2.0.5",
    "protobufjs": "^7.6.5",
    "uuid": "^11.1.1",
    "minimatch@3": {
      "brace-expansion": "^1.1.16"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anchit2000/dhaga.git"
  },
  "scripts": {
    "dev": "npm run dev --prefix apps/web",
    "build": "npm run build --prefix apps/web",
    "lint": "npm run lint --prefix apps/web",
    "start": "npm run start --prefix apps/web",
    "test:e2e:graph-focus": "node tests/scripts/verify-graph-focus.mjs"
  }
}
