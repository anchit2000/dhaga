# Dhaga Cloud only — see LICENSE. Self-hosted instances don't need any of
# this; leave DHAGA_HOSTED_MODE unset and none of it is ever read.

# Turns on early-access gating, the admin panel, and Stripe billing. All
# three read/write real Postgres (RLS) — DATABASE_URL (in apps/web/.env)
# must point at a real Postgres instance, not the embedded PGlite default.
DHAGA_HOSTED_MODE=true

# Bootstrap admin escape hatch — comma-separated emails treated as admin
# before anyone has flipped the isAdmin flag through the (not yet built)
# UI for it.
DHAGA_ADMIN_EMAILS=

# Stripe (test mode keys while developing: https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from the Stripe Dashboard — Products.
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_LIFETIME=
